# ─────────────────────────────────────────────────────────────────────────────
# Hindi Voice Collection Bot — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── TTS Provider ──────────────────────────────────────────────────────────────
# Options: edge_tts | elevenlabs
TTS_PROVIDER=edge_tts

# edge-tts voices (no API key required)
# Female: hi-IN-SwaraNeural | Male: hi-IN-MadhurNeural
EDGE_TTS_DEFAULT_VOICE=hi-IN-SwaraNeural
EDGE_TTS_VOICE_FEMALE=hi-IN-SwaraNeural
EDGE_TTS_VOICE_MALE=hi-IN-MadhurNeural

# ElevenLabs (optional — only used if TTS_PROVIDER=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── STT Provider ──────────────────────────────────────────────────────────────
# Options: browser | faster_whisper
# browser = uses browser Web Speech API (no backend required, recommended for POC)
# faster_whisper = uses local Faster-Whisper model (requires installation)
STT_PROVIDER=browser

# Whisper model size (only used if STT_PROVIDER=faster_whisper)
# Options: tiny | small | medium | large
WHISPER_MODEL_SIZE=small

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Session ───────────────────────────────────────────────────────────────────
# How long (in seconds) before a session is considered expired
SESSION_TIMEOUT_SECONDS=3600
